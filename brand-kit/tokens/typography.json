{
  "$schema": "https://design-tokens.org/schema.json",
  "fontFamily": {
    "display": {
      "value": "'Bebas Neue', sans-serif",
      "type": "fontFamily",
      "description": "Headlines, hero text, section titles"
    },
    "sans": {
      "value": "'DM Sans', sans-serif",
      "type": "fontFamily",
      "description": "Body text, UI elements"
    },
    "mono": {
      "value": "'Geist Mono', monospace",
      "type": "fontFamily",
      "description": "Code, data, technical content"
    }
  },
  "fontWeight": {
    "regular": {
      "value": 400,
      "type": "fontWeight"
    },
    "medium": {
      "value": 500,
      "type": "fontWeight"
    },
    "semibold": {
      "value": 600,
      "type": "fontWeight"
    },
    "bold": {
      "value": 700,
      "type": "fontWeight"
    }
  },
  "fontSize": {
    "hero": {
      "value": "7rem",
      "type": "fontSize",
      "description": "112px - Hero headlines"
    },
    "h1": {
      "value": "4rem",
      "type": "fontSize",
      "description": "64px - Page titles"
    },
    "h2": {
      "value": "3rem",
      "type": "fontSize",
      "description": "48px - Section titles"
    },
    "h3": {
      "value": "2rem",
      "type": "fontSize",
      "description": "32px - Subsection titles"
    },
    "h4": {
      "value": "1.5rem",
      "type": "fontSize",
      "description": "24px - Card titles"
    },
    "body-lg": {
      "value": "1.25rem",
      "type": "fontSize",
      "description": "20px - Large body text"
    },
    "body": {
      "value": "1rem",
      "type": "fontSize",
      "description": "16px - Default body text"
    },
    "body-sm": {
      "value": "0.875rem",
      "type": "fontSize",
      "description": "14px - Small body text"
    },
    "caption": {
      "value": "0.75rem",
      "type": "fontSize",
      "description": "12px - Captions, labels"
    }
  },
  "lineHeight": {
    "tight": {
      "value": 1.0,
      "type": "lineHeight",
      "description": "Display headlines"
    },
    "snug": {
      "value": 1.2,
      "type": "lineHeight",
      "description": "Headings"
    },
    "normal": {
      "value": 1.5,
      "type": "lineHeight",
      "description": "Body text"
    },
    "relaxed": {
      "value": 1.6,
      "type": "lineHeight",
      "description": "Long-form content"
    }
  },
  "letterSpacing": {
    "tight": {
      "value": "-0.025em",
      "type": "letterSpacing"
    },
    "normal": {
      "value": "0",
      "type": "letterSpacing"
    },
    "wide": {
      "value": "0.025em",
      "type": "letterSpacing"
    },
    "wider": {
      "value": "0.05em",
      "type": "letterSpacing"
    },
    "widest": {
      "value": "0.1em",
      "type": "letterSpacing"
    }
  },
  "textStyles": {
    "hero": {
      "fontFamily": "{fontFamily.display}",
      "fontSize": "{fontSize.hero}",
      "fontWeight": "{fontWeight.regular}",
      "lineHeight": "{lineHeight.tight}",
      "letterSpacing": "{letterSpacing.wide}",
      "textTransform": "uppercase"
    },
    "h1": {
      "fontFamily": "{fontFamily.display}",
      "fontSize": "{fontSize.h1}",
      "fontWeight": "{fontWeight.regular}",
      "lineHeight": "{lineHeight.snug}",
      "letterSpacing": "{letterSpacing.wide}",
      "textTransform": "uppercase"
    },
    "h2": {
      "fontFamily": "{fontFamily.display}",
      "fontSize": "{fontSize.h2}",
      "fontWeight": "{fontWeight.regular}",
      "lineHeight": "{lineHeight.snug}",
      "letterSpacing": "{letterSpacing.wide}",
      "textTransform": "uppercase"
    },
    "h3": {
      "fontFamily": "{fontFamily.display}",
      "fontSize": "{fontSize.h3}",
      "fontWeight": "{fontWeight.regular}",
      "lineHeight": "{lineHeight.snug}",
      "letterSpacing": "{letterSpacing.wide}",
      "textTransform": "uppercase"
    },
    "body-lg": {
      "fontFamily": "{fontFamily.sans}",
      "fontSize": "{fontSize.body-lg}",
      "fontWeight": "{fontWeight.regular}",
      "lineHeight": "{lineHeight.relaxed}"
    },
    "body": {
      "fontFamily": "{fontFamily.sans}",
      "fontSize": "{fontSize.body}",
      "fontWeight": "{fontWeight.regular}",
      "lineHeight": "{lineHeight.normal}"
    },
    "body-sm": {
      "fontFamily": "{fontFamily.sans}",
      "fontSize": "{fontSize.body-sm}",
      "fontWeight": "{fontWeight.regular}",
      "lineHeight": "{lineHeight.normal}"
    },
    "label": {
      "fontFamily": "{fontFamily.sans}",
      "fontSize": "{fontSize.body-sm}",
      "fontWeight": "{fontWeight.medium}",
      "letterSpacing": "{letterSpacing.wider}",
      "textTransform": "uppercase"
    },
    "caption": {
      "fontFamily": "{fontFamily.sans}",
      "fontSize": "{fontSize.caption}",
      "fontWeight": "{fontWeight.medium}",
      "letterSpacing": "{letterSpacing.widest}",
      "textTransform": "uppercase"
    }
  }
}
